def processo_analitico():
    print("=== SOFTWARE ANALÍTICO - QUÍMICA EXPERTA ===")

    # Caminho óptico é quase sempre 1.0, facilitamos para o usuário
    c_optico = input('Caminho óptico (cm) [Padrão 1.0]: ')
    caminho_optico = float(c_optico) if c_optico else 1.0

    cas_usuario = input("Digite o número CAS (ou Enter para Curva de Calibração): ").strip()

    if cas_usuario in compostos_db:
        dados = compostos_db[cas_usuario]
        print(f"Usando dados de: {dados['nome']}")
        conc = float(input(f"Insira a concentração de {dados['nome']} (mol/L): "))
        #lei de beer
        absorbancia = dados['coeficiente_molar'] * caminho_optico * conc
        return f"Absorbância Calculada (Beer-Lambert): {absorbancia:.4f}"

    elif cas_usuario != "":
        print("CAS não encontrado no banco local.")
        opcao = input("1. Buscar no PubChem / 2. Cadastrar Manual / 3. Ir para Curva: ")

        if opcao == '1':
            if adicionar_via_cas(cas_usuario):
                print("Composto salvo! Reinicie para calcular.")
            return "Operação de cadastro finalizada."
        elif opcao == '2':
            nome = input("Nome do composto: ")
            coeficiente_absorção_molar = input("Coeficiente (ε): ").replace(',','.')
            nm = float(input("Comprimento de onda (nm): "))
            compostos_db[cas_usuario] = {'nome': nome, 'coeficiente_molar': coeficiente_absorção_molar, 'nm': nm}
            salvar_biblioteca()
            return "Composto cadastrado manualmente."


    # Se caiu aqui, vai para a curva
    return iniciar_curva_calibracao()

