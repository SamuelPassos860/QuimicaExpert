def iniciar_curva_calibracao():
    print("\n--- MODO: CURVA DE CALIBRAÇÃO (y = mx + b) ---")
    m = float(input('Inclinação da curva (m): '))
    b = float(input('Intersecção da curva (b): '))
    abs_lida = float(input('Absorbância lida na amostra: '))
    # x = (y - b) / m
    concentracao = (abs_lida - b) / m
    return f"Resultado via Curva: Concentração = {concentracao:.4f} mol/L"
